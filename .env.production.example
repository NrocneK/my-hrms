# ════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT VARIABLES
# Copy các giá trị này vào Vercel Dashboard
# ════════════════════════════════════════════════

# Database — PlanetScale
# Format: mysql://username:password@host/database?sslaccept=strict
DATABASE_URL="mysql://xxxxxxxx:pscale_pw_xxxxxxxx@aws.connect.psdb.cloud/my-hrms?sslaccept=strict"

# NextAuth
# Tạo secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="your-super-secret-key-here"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="hrms_avatars"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

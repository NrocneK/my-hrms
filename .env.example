# ====================================================
# DATABASE - Chọn 1 trong 2 cấu hình bên dưới
# ====================================================

# Option 1: Local MySQL (XAMPP) - dùng khi dev trên máy
DATABASE_URL="mysql://root:@localhost:3306/my_hrms"
# Giải thích:
#   root     = username mặc định của XAMPP
#   (trống)  = password mặc định của XAMPP (không có password)
#   localhost = máy tính của bạn
#   3306     = port MySQL mặc định
#   my_hrms  = tên database (tạo trong phpMyAdmin trước)

# Option 2: PlanetScale (production/cloud)
# DATABASE_URL="mysql://username:password@host/database?sslaccept=strict"

# ====================================================
# NEXTAUTH
# ====================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"
# Tạo secret bằng lệnh:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
